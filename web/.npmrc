# legacy-peer-deps: the Solana wallet-adapter pulls @keystonehq/sdk, which
# brings react-qr-reader / qrcode.react (peer react ~16/17) and a react-native
# chain (peer react@^19), both conflicting with the app's react@18.3.1. Strict
# peer resolution errors on that; legacy mode installs the tree the committed
# web/package-lock.json was generated against.
#
# Scoped to web/ ONLY — npm reads .npmrc from cwd upward, and this dir is not an
# ancestor of the repo root, so the parent `npm ci` still resolves strictly and
# keeps the @pump-fun/pump-sdk override. Mirrors .github/workflows/smoke.yml,
# which passes --legacy-peer-deps for the web job only.
legacy-peer-deps=true
