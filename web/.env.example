# SolVerdict web app — environment variables.
# Copy to .env.local for local dev (never commit .env.local).

# --- Upstash Redis (state + audit queue) ---
# Create a database at https://console.upstash.com and copy the REST creds.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Model provider keys (used by the audit-worker when it runs the bench) ---
# Only required in the GitHub Actions worker environment, not for the web UI.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
