# SolVerdict web app — environment variables.
# Copy to .env.local for local dev (never commit .env.local).

# --- Upstash Redis (state + audit queue) ---
# Create a database at https://console.upstash.com and copy the REST creds.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Payment (Sprint 3) ---
# Solana address that receives USDC for paid audits (server-side verification).
SOLVERDICT_PAYMENT_WALLET=
# Same address exposed to the browser so the submit page can build the payment tx.
NEXT_PUBLIC_SOLVERDICT_PAYMENT_WALLET=
# USDC mainnet mint (client + server).
NEXT_PUBLIC_USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
# Solana RPC used to verify payment transactions (public endpoint OK for MVP).
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# Optional client RPC for the wallet ConnectionProvider (defaults to clusterApiUrl).
# NEXT_PUBLIC_SOLANA_RPC_URL=

# --- Wallet adapter (client) ---
NEXT_PUBLIC_WALLET_ADAPTER_NETWORK=mainnet-beta

# --- Email notifications (Sprint 3, Resend) ---
# https://resend.com — free tier ~3000 emails/month.
RESEND_API_KEY=
# Verified sender (optional; defaults to "SolVerdict <audits@solverdict.dev>").
RESEND_FROM=
# Public base URL used to build /audit/<id> links in emails.
NEXT_PUBLIC_BASE_URL=

# --- Worker knobs (GitHub Action env) ---
# AUDIT_ID: run a specific audit (else the worker drains audit_queue)
# DRAIN_MAX: max audits processed per cron tick (default 5)
