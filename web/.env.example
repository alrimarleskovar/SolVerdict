# SolVerdict web app — environment variables.
# Copy to .env.local for local dev (never commit .env.local).

# --- Upstash Redis (state + audit queue) ---
# Create a database at https://console.upstash.com and copy the REST creds.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Model provider keys ---
# NOT used by the Sprint 2 worker: it benches the user's live endpoint, which
# uses its OWN keys. Kept here only as placeholders for local experimentation.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Worker knobs (GitHub Action env) ---
# AUDIT_ID: run a specific audit (else the worker pops audit_queue)
# AUDIT_N:  runs per scenario (default 1; the pre-registered board is N=20)
