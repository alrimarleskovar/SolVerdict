{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(npm *)", "Bash(npx *)", "Bash(pnpm *)", "Bash(node *)",
      "Bash(cargo *)", "Bash(mkdir *)", "Bash(ls *)", "Bash(cat *)",
      "Bash(surfpool *)", "Bash(solana *)"
    ],
    "deny": [
      "Bash(git *)",
      "Read(./.env)", "Read(./.env.*)",
      "Write(./.env)", "Write(./.env.*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      { "matcher": "Bash",
        "hooks": [ { "type": "command", "command": "$CLAUDE_PROJECT_DIR/scripts/block-git.sh" } ] }
    ]
  }
}
